{
  "name": "kenshi-mod-manager",
  "version": "1.1.0",
  "description": "A Kenshi mod load order manager with category sorting, conflict detection, AI-assisted sorting, and mod packs",
  "main": "main.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Derthi/kenshi-mod-manager"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win dir"
  },
  "build": {
    "appId": "com.kenshi.mod-sorter",
    "productName": "BEEP Kenshi Mod Manager",
    "win": {
      "target": "dir",
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.ico",
      "lib/**/*",
      "renderer/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "rcedit": "^5.0.2"
  }
}
